@page "/perfil/{id}"
@namespace WaylanOrigin.Client.Pages
@using WaylanOrigin.Client.Models
@using System.Linq

<div class="perfil-container">

    <!-- HERO SECTION (Imagen de fondo completa + degradado) -->
    <div class="perfil-hero"
         style="
            background-image: 
                linear-gradient(to right, rgba(28, 15, 8, 0.85) 35%, rgba(28, 15, 8, 0.2) 100%), 
                url('@productor.ImagenPrincipal');
            background-position: center center;   /* ← CORREGIDO */
            background-size: cover;               /* ← CORREGIDO */
         ">

        <!-- Breadcrumb -->
        <div class="breadcrumb">
            <a href="/productores">← Productores Aliados</a>
            <span class="separator">&gt;</span>
            <a href="/famycafe">FAMYCAFE</a>
            <span class="separator">&gt;</span>
            <span class="active">@productor.Nombre</span>
        </div>

        <!-- Info del productor -->
        <div class="perfil-hero-info">
            <h1 class="perfil-nombre">@productor.Nombre</h1>

            <p class="perfil-ubicacion">
                📍 @productor.Finca — @productor.Ubicacion
            </p>

            <p class="perfil-frase">
                “@productor.Frase”
            </p>
        </div>

    </div>

    <!-- TABS -->
    <div class="perfil-tabs">
        <button class="perfil-tab perfil-tab-activo">Historia</button>
        <button class="perfil-tab">Finca</button>
        <button class="perfil-tab">Procesos</button>
        <button class="perfil-tab">Variedades</button>
        <button class="perfil-tab">Lotes</button>
        <button class="perfil-tab">Reconocimientos</button>
        <button class="perfil-tab">Galería</button>
    </div>

    <!-- CONTENIDO -->
    <div class="perfil-contenido">

        <div class="perfil-historia">
            <h2>@productor.HistoriaTitulo</h2>
            <p>@productor.HistoriaTexto</p>

            <a href="#" class="btn-leer-mas">
                Leer más <span class="flecha">&rarr;</span>
            </a>
        </div>

        <div class="perfil-ficha">
            <div class="ficha-grid">

                <div class="ficha-item border-r border-b">
                    <div class="icon-placeholder"></div>
                    <div class="ficha-text">
                        <span class="ficha-valor">@productor.Altitud</span>
                        <span class="ficha-label">Altitud</span>
                    </div>
                </div>

                <div class="ficha-item border-b">
                    <div class="icon-placeholder"></div>
                    <div class="ficha-text">
                        <span class="ficha-valor">@productor.Variedades</span>
                        <span class="ficha-label">Variedades</span>
                    </div>
                </div>

                <div class="ficha-item border-r">
                    <div class="icon-placeholder"></div>
                    <div class="ficha-text">
                        <span class="ficha-valor">@productor.Proceso</span>
                        <span class="ficha-label">Proceso</span>
                    </div>
                </div>

                <div class="ficha-item">
                    <div class="icon-placeholder"></div>
                    <div class="ficha-text">
                        <span class="ficha-valor">@productor.Experiencia</span>
                        <span class="ficha-label">Experiencia</span>
                    </div>
                </div>

            </div>
        </div>

    </div>

    <!-- GALERÍA -->
    <div class="perfil-galeria">
        @if (productor.Galeria != null && productor.Galeria.Any())
        {
            @foreach (var img in productor.Galeria)
            {
                <div class="perfil-galeria-item">
                    <img src="@img" alt="Imagen de @productor.Nombre" />
                </div>
            }
        }
    </div>

</div>

@code {
    [Parameter]
    public string id { get; set; }

    private ProductorModel productor;

    protected override void OnInitialized()
    {
        productor = ProductoresData.Lista.FirstOrDefault(p => p.Id == id);

        if (productor == null)
        {
            productor = new ProductorModel
            {
                Nombre = "Productor no encontrado",
                Finca = "",
                Ubicacion = "",
                Frase = "",
                HistoriaTitulo = "",
                HistoriaTexto = "",
                Altitud = "",
                Proceso = "",
                Variedades = "",
                Experiencia = "",
                ImagenPrincipal = "/imagenes/productores/default.png",
                Galeria = new List<string>()
            };
        }
    }
}
