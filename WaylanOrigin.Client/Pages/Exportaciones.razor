@page "/exportaciones"

<PageTitle>Exportaciones | Waylan Origin</PageTitle>

<div class="waylan-export-page">

    @* --- SECCIÓN 1: HERO ORIGINAL --- *@
    <section class="ex-hero">
        <div class="ex-hero-container">
            <div class="ex-hero-content">
                <span class="ex-tag-gold">EXPORTACIONES</span>
                <h1 class="ex-title-white">Llevamos el origen <br /><span class="ex-serif-italic">a cada rincón</span> del mundo</h1>
                <p class="ex-desc-white">
                    En Waylan Origin exportamos café de especialidad que refleja la esencia de nuestras montañas,
                    el trabajo de nuestras familias productoras y nuestro compromiso con la calidad y la sostenibilidad.
                </p>

                <div class="ex-hero-features">
                    <div class="ex-feat-item">
                        <div class="ex-icon-container">
                            <img src="/logotipo/e1.png" alt="Origen" style="width:100%; height:100%; object-fit:contain;" />
                        </div>
                        <div class="ex-feat-text">
                            <h3>100% Café de origen</h3>
                            <p>Tolima, Colombia</p>
                        </div>
                    </div>
                    <div class="ex-feat-item">
                        <div class="ex-icon-container">
                            <img src="/logotipo/e2.png" alt="Trazabilidad" style="width:100%; height:100%; object-fit:contain;" />
                        </div>
                        <div class="ex-feat-text">
                            <h3>Trazabilidad</h3>
                            <p>en cada lote</p>
                        </div>
                    </div>
                    <div class="ex-feat-item">
                        <div class="ex-icon-container">
                            <img src="/logotipo/e3.png" alt="Calidad" style="width:100%; height:100%; object-fit:contain;" />
                        </div>
                        <div class="ex-feat-text">
                            <h3>Calidad que cumple</h3>
                            <p>estándares globales</p>
                        </div>
                    </div>
                    <div class="ex-feat-item">
                        <div class="ex-icon-container">
                            <img src="/logotipo/e4.png" alt="Relaciones" style="width:100%; height:100%; object-fit:contain;" />
                        </div>
                        <div class="ex-feat-text">
                            <h3>Relaciones justas</h3>
                            <p>y duraderas</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="ex-hero-image-wrap">
                <img src="/imagenes/exp.png" alt="Waylan Origin Export" class="ex-hero-img-fluid" />
            </div>
        </div>
    </section>

    @* --- BLOQUE UNIFICADO DESTINOS Y PROCESO --- *@
    <div class="ex-unified-blocks">

        @* --- SECCIÓN 2: MAPA DE DESTINOS --- *@
        <section class="waylan-destinos-rebuild">
            <div class="destinos-layout-container">

                @* Columna Izquierda: Texto Superior + Tarjetas *@
                <div class="destinos-col-left">

                    @* Bloque de texto superior *@
                    <div class="destinos-text-header">

                        <div class="waylan-sub-header">
                            <img src="/logotipo/z1.png" class="mini-cafe-icon" alt="Waylan Icon" />
                            <span class="waylan-sub-label">UN CAFÉ QUE CRUZA FRONTERAS</span>
                        </div>

                        <h2 class="destinos-heading">
                            <span class="text-charcoal">Presentes en los</span>
                            <span class="serif-italic-gold">mercados más exigentes</span>
                        </h2>

                        <p class="destinos-sub">
                            Nuestro café ha llegado a países que valoran la calidad, la sostenibilidad y las historias reales detrás de cada taza.
                        </p>

                        <div class="export-line-container">
                            <span class="export-tag">EXPORTAMOS A:</span>
                            <div class="gold-horizontal-line"></div>
                        </div>

                    </div>

                    @* Grilla de tarjetas robustas 4x2 *@
                    <div class="destinos-cards-wrapper">

                        @* Fila 1 *@
                        <div class="destinos-row">
                            <div class="destino-card">
                              <div class="destino-landmark"><img src="/logotipo/n1.png" alt="Usa" /></div>
                                <img src="/logotipo/p1.png" class="destino-flag" alt="USA">
                                <span class="destino-name">USA</span>
                            </div>

                            <div class="destino-card">
                                <div class="destino-landmark"><img src="/logotipo/n2.png" alt="Canadá" /></div>
                                <img src="/logotipo/p2.png" class="destino-flag" alt="Canada">
                                <span class="destino-name">CAN</span>
                            </div>

                            <div class="destino-card">
                                <div class="destino-landmark"><img src="/logotipo/n3.png" alt="Alemania" /></div>
                                <img src="/logotipo/p3.png" class="destino-flag" alt="Germany">
                                <span class="destino-name">DEU</span>
                            </div>

                            <div class="destino-card">
                                <div class="destino-landmark"><img src="/logotipo/n4.png" alt="Japón" /></div>  
                                <img src="/logotipo/p4.png" class="destino-flag" alt="Japan">
                                <span class="destino-name">JPN</span>
                            </div>
                        </div>

                        @* Fila 2 *@
                        <div class="destinos-row">
                            <div class="destino-card">
                                <div class="destino-landmark"><img src="/logotipo/n5.png" alt="Corea del Sur" /></div>
                                <img src="/logotipo/p5.png" class="destino-flag" alt="South Korea">
                                <span class="destino-name">KOR</span>
                            </div>

                            <div class="destino-card">
                                <div class="destino-landmark"><img src="/logotipo/n6.png" alt="Australia" /></div>
                                <img src="/logotipo/p6.png" class="destino-flag" alt="Australia">
                                <span class="destino-name">AUS</span>
                            </div>

                            <div class="destino-card">
                                <div class="destino-landmark"><img src="/logotipo/n7.png" alt="Bélgica" /></div>
                                <img src="/logotipo/p7.png" class="destino-flag" alt="Belgium">
                                <span class="destino-name">BEL</span>
                            </div>

                            <div class="destino-card">                               
                                <div class="destino-landmark"><img src="/logotipo/n8.png" alt="Suecia" /></div>    
                                <img src="/logotipo/p8.png" class="destino-flag" alt="Sweden">
                                <span class="destino-name">SWE</span>
                            </div>
                        </div>

                    </div>
                </div>

                @* Columna Derecha: El Mapa *@
                <div class="destinos-col-right">
                    <img src="/imagenes/mundo.png" class="destinos-main-img" alt="Mapa de Destinos">
                </div>

            </div>
        </section>

       @* --- SECCIÓN 3: PROCESO --- *@
        <div class="ex-process-section">
            <div class="ex-process-separator">
                <img src="/logotipo/z1.png" style="width: 24px; height: 24px; object-fit: contain;" alt="Waylan Icon" />
                <span class="ex-sep-text">UN CAFÉ QUE CRUZA FRONTERAS</span>
            </div>

            <h2 class="ex-process-title">Proceso de Exportación</h2>
            <p class="ex-process-subtitle">Un proceso cuidadoso que garantiza que cada lote llegue en las mejores condiciones.</p>

            <div class="ex-horizontal-timeline">
                <div class="ex-timeline-step">
                    <div class="ex-step-circle">
                        <img src="/logotipo/l1.png" class="ex-step-img" alt="Selección" />
                    </div>
                    <h4 class="ex-step-title">1.Selección</h4>
                    <p class="ex-step-desc">Elegimos los mejores granos desde el origen.</p>
                </div>

                <div class="ex-timeline-step">
                    <div class="ex-step-circle">
                        <img src="/logotipo/l2.png" class="ex-step-img" alt="Preparación" />
                    </div>
                    <h4 class="ex-step-title">2.Preparación</h4>
                    <p class="ex-step-desc">Procesos controlados y café de alta calidad.</p>
                </div>

                <div class="ex-timeline-step">
                    <div class="ex-step-circle">
                        <img src="/logotipo/l3.png" class="ex-step-img" alt="Control de calidad" />
                    </div>
                    <h4 class="ex-step-title">3.Control de calidad</h4>
                    <p class="ex-step-desc">Evaluamos cada lote para cumplir estándares exigentes.</p>
                </div>

                <div class="ex-timeline-step">
                    <div class="ex-step-circle">
                        <img src="/logotipo/l4.png" class="ex-step-img" alt="Empaque" />
                    </div>
                    <h4 class="ex-step-title">4.Empaque</h4>
                    <p class="ex-step-desc">Empacamos cuidadosamente para proteger su frescura.</p>
                </div>

                <div class="ex-timeline-step">
                    <div class="ex-step-circle">
                        <img src="/logotipo/l5.png" class="ex-step-img" alt="Exportación" />
                    </div>
                    <h4 class="ex-step-title">5.Exportación</h4>
                    <p class="ex-step-desc">Enviamos nuestro café al mundo con confianza.</p>
                </div>

                <div class="ex-timeline-step">
                    <div class="ex-step-circle">
                        <img src="/logotipo/l6.png" class="ex-step-img" alt="Experiencia" />
                    </div>
                    <h4 class="ex-step-title">6.Experiencia</h4>
                    <p class="ex-step-desc">Lleva nuestro origen a nuevas historias y experiencias.</p>
                </div>
            </div> @* <--- AQUÍ TERMINABA LA LÍNEA DE TIEMPO *@
        </div> @* <--- AQUÍ TERMINA LA SECCIÓN DEL PROCESO DE EXPORTACIÓN *@

    </div> @* <--- CIERRA EL CONTENEDOR UNIFICADO (ex-unified-blocks) *@

    @* === SECCIÓN 4: CAFÉ DE ESPECIALIDAD (YA QUEDA ABAJO) === *@
    <div class="ex-specialty-section">
        <div class="ex-specialty-grid">
            <div class="ex-spec-card ex-spec-text-block">
                <span class="ex-tag-gold">CAFÉ DE ESPECIALIDAD</span>
                <p class="ex-spec-main-desc">Ofrecemos diferentes perfiles y presentaciones para satisfacer las necesidades de tostadores, distribuidores y amantes del buen café.</p>
                <div class="ex-spec-mini-features">
                    <div class="ex-mini-feat">
                        <img src="logotipo/h1.png" alt="Perfiles" />
                        <span>Perfiles personalizados</span>
                    </div>
                    <div class="ex-mini-feat">
                        <img src="logotipo/h2.png" alt="Microlotes" />
                        <span>Microlotes exclusivos</span>
                    </div>
                    <div class="ex-mini-feat">
                        <img src="logotipo/h3.png" alt="Volúmenes" />
                        <span>Volúmenes flexibles</span>
                    </div>
                    <div class="ex-mini-feat">
                        <img src="logotipo/h4.png" alt="Documentación" />
                        <span>Documentación completa</span>
                    </div>
                </div>
            </div>

            <div class="ex-spec-card ex-spec-image-card">
                <div class="ex-spec-img-wrap">
                    <img src="/imagenes/ver.png" alt="Calidad y consistencia" />
                </div>
                <div class="ex-spec-card-body">
                    <h4>CALIDAD Y CONSISTENCIA</h4>
                    <p>Granos seleccionados con estrictos controles para garantizar uniformidad en cada envío.</p>
                </div>
            </div>

            <div class="ex-spec-card ex-spec-image-card">
                <div class="ex-spec-img-wrap">
                    <img src="/imagenes/bar.png" alt="Logística confiable" />
                </div>
                <div class="ex-spec-card-body">
                    <h4>LOGÍSTICA CONFIABLE</h4>
                    <p>Trabajamos con aliados logísticos internacionales para asegurar entregas seguras y puntuales.</p>
                </div>
            </div>

            <div class="ex-spec-card ex-spec-image-card">
                <div class="ex-spec-img-wrap">
                    <img src="/imagenes/bul.png" alt="Presentaciones" />
                </div>
                <div class="ex-spec-card-body">
                    <h4>PRESENTACIONES</h4>
                    <p>Empaque en sacos GrainPro y opciones de marca privada según las necesidades de cada cliente.</p>
                </div>
            </div>

            <div class="ex-spec-card ex-spec-image-card">
                <div class="ex-spec-img-wrap">
                    <img src="/imagenes/on.png" alt="Trazabilidad total" />
                </div>
                <div class="ex-spec-card-body">
                    <h4>TRAZABILIDAD TOTAL</h4>
                    <p>Cada lote cuenta con información completa sobre origen, productor y proceso.</p>
                </div>
            </div>
        </div>
    </div>

    @* === SECCIÓN 5: NUESTRO COMPROMISO === *@
    <div class="ex-compromiso-section">
        <div class="ex-compromiso-container">
            <div class="ex-comp-img-side">
                <img src="/imagenes/espal.png" alt="Caficultor Waylan" />
            </div>

            <div class="ex-comp-content-side">
                <span class="ex-tag-gold">NUESTRO COMPROMISO</span>
                <h2>Más que exportar café, <br><span class="ex-serif-italic">construimos relaciones.</span></h2>
                <p class="ex-comp-lead">Creemos en alianzas a largo plazo basadas en la confianza, el respeto y el crecimiento mutuo. Nuestro propósito es seguir llevando café que transforma realidades.</p>
                
                <div class="ex-comp-badges">
                    <div class="ex-badge-item">
                        <img src="/logotipo/m1.png" alt="Relaciones" />
                        <p>Relaciones a largo plazo</p>
                    </div>
                    <div class="ex-badge-item">
                        <img src="/logotipo/m2.png" alt="Communication" />
                        <p>Comunicación transparente</p>
                    </div>
                    <div class="ex-badge-item">
                        <img src="/logotipo/m3.png" alt="Sostenibilidad" />
                        <p>Compromiso con la sostenibilidad</p>
                    </div>
                    <div class="ex-badge-item">
                        <img src="/logotipo/m4.png" alt="Impacto" />
                        <p>Impacto positivo en las comunidades</p>
                    </div>
                </div>
                
                <div class="ex-contact-cta">
                    <div class="ex-cta-inner">
                        <div class="ex-cta-text">
                            <h3>¿Quieres llevar Waylan Origin a tu mercado?</h3>
                            <p>Hablemos y construyamos juntos nuevas historias alrededor del café.</p>
                        </div>
                       <a href="/contacto" class="ex-btn-gold">CONTÁCTANOS <span>&gt;</span></a>

                    </div>
                </div>
            </div>
        </div>
    </div>

</div> @* <--- ÚNICO CIERRE AL FINAL: CIERRA LA PAGINA COMPLETA (waylan-export-page) *@

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@1,400;1,500&display=swap');

    .waylan-export-page {
        width: 100%;
        box-sizing: border-box;
        background-color: #F6F4EE !important;
        color: #2E1A11 !important;
        font-family: 'Montserrat', sans-serif;
        margin: 0;
        padding: 0;
        overflow-x: hidden;
    }

    .waylan-export-page *, .waylan-export-page *::before, .waylan-export-page *::after {
        box-sizing: border-box;
    }

    .ex-serif-italic {
        font-family: 'Playfair Display', serif;
        font-style: italic;
        color: #C5A880 !important;
    }

    .ex-tag-gold {
        color: #C5A880;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 2px;
        display: block;
        margin-bottom: 25px;
    }

    /* --- HERO ORIGINAL --- */
    .ex-hero {
        background-color: #1A1310 !important;
        padding: 0 0 0 6%;
        min-height: 85vh;
        display: flex;
        align-items: center;
        overflow: hidden;
        position: relative;
    }

    .ex-hero-container {
        display: flex;
        width: 100%;
        max-width: 1400px;
        margin: 0 0 0 auto;
        gap: 40px;
        align-items: center;
    }

    .ex-hero-content {
        flex: 1.2;
        padding: 60px 0 40px 0;
    }

    .ex-title-white {
        color: #FFFFFF !important;
        font-size: 3rem !important;
        font-weight: 500;
        line-height: 1.2;
        margin: 0 0 25px 0 !important;
    }

    .ex-desc-white {
        color: #C5B6A8 !important;
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 50px;
        max-width: 580px;
    }

    .ex-hero-features {
        display: flex;
        width: 100%;
        max-width: 800px;
        margin-top: 20px;
    }

    .ex-feat-item {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
        padding-right: 15px;
        border-right: 1px solid rgba(197, 168, 128, 0.2);
    }

    .ex-feat-item:last-child {
        border-right: none;
        padding-right: 0;
    }

    .ex-icon-container {
        width: 80px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: flex-start;
    }

    .ex-feat-text h3 {
        color: #C5A880 !important;
        font-size: 0.85rem !important;
        margin: 0 0 4px 0 !important;
        font-weight: 600;
    }

    .ex-feat-text p {
        color: #E6DFDA !important;
        font-size: 0.8rem !important;
        margin: 0 !important;
    }

    .ex-hero-image-wrap {
        flex: 0.8;
        display: flex;
        justify-content: flex-end;
        align-items: stretch;
        height: 85vh;
        align-self: flex-end;
    }

    .ex-hero-img-fluid {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: left center;
        mask-image: linear-gradient(to right, transparent 0%, #000000 15%, #000000 100%);
    }

    .ex-unified-blocks {
        padding-bottom: 80px;
        background-color: #F6F4EE !important;
    }

    /* --- SECCIÓN DESTINOS --- */
    .waylan-destinos-rebuild .destinos-layout-container {
        max-width: 1350px;
        margin: 0 auto;
        display: flex;
        flex-direction: row;
        align-items: stretch;
        gap: 30px;
        padding-top: 10px;
        padding-bottom: 10px;
    }

    .destinos-col-left {
        flex: 1.2;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
    }

    .destinos-text-header {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .waylan-sub-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 12px;
    }

    .mini-cafe-icon {
        width: 80px;
        height: 80px;
        object-fit: contain;
    }

    .waylan-sub-label {
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 2.5px;
        color: #B59A73 !important;
    }

    .destinos-heading {
        font-size: 3.2rem;
        font-weight: 500;
        line-height: 1.15;
        margin: 0 0 18px 0;
        font-family: 'Playfair Display', serif;
    }

    .destinos-heading .text-charcoal {
        color: #231F20 !important;
    }

    .destinos-heading .serif-italic-gold {
        font-family: 'Playfair Display', serif;
        font-style: italic;
        color: #B59A73 !important;
        font-weight: 400;
    }

    .destinos-sub {
        font-size: 1.05rem;
        color: #55504E !important;
        line-height: 1.7;
        max-width: 580px;
        margin-bottom: 35px;
    }

    .export-line-container {
        display: flex;
        align-items: center;
        width: 100%;
        max-width: 580px;
        gap: 15px;
        margin-bottom: 45px;
    }

    .export-tag {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        color: #B59A73 !important;
        white-space: nowrap;
    }

    .gold-horizontal-line {
        flex-grow: 1;
        height: 1px;
        background-color: #B59A73 !important;
        position: relative;
    }

    .gold-horizontal-line::after {
        content: '';
        position: absolute;
        right: 0;
        top: -2px;
        width: 5px;
        height: 5px;
        background-color: #B59A73;
        border-radius: 50%;
    }

    .destinos-cards-wrapper {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .destinos-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
    }

    .destino-card {
    background-color: #FFFFFF;
    border: 1px solid #E4DCD3;
    border-radius: 6px;
    padding: 12px 8px;   /* Un pelín más de espacio arriba y abajo */
    height: 115px;       /* Subimos de 115px a 145px para que quepa el monumento perfectamente sin mover la grilla */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between; /* Distribuye el contenido limpio de arriba a abajo */
    transition: all 0.25s ease;
}

.destino-card {
    background-color: #FFFFFF;
    border: 1px solid #E4DCD3;
    border-radius: 6px;
    padding: 10px 8px;   /* Volvemos a un padding compacto */
    height: 115px;       /* TU TAMAÑO ORIGINAL FIJO (Tarjetas chiquitas) */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center; /* Cambiado a center para controlar los espacios con márgenes */
    transition: all 0.25s ease;
    overflow: hidden;    /* Evita que se deforme la tarjeta */
}

.destino-card:hover {
    border-color: #C5A880;
    box-shadow: 0 12px 28px rgba(46, 26, 17, 0.08);
}

/* --- LOGOS MÁS GRANDES AQUÍ --- */
.destino-landmark {
    display: flex !important;
    justify-content: center;
    align-items: center;
    height: 48px;       /* SUBIDO A 48px: Aquí controlas el tamaño del monumento sin alterar la tarjeta */
    width: 100%;
    margin-bottom: 6px; /* Espacio controlado respecto a la bandera */
}

.destino-landmark img {
    height: 100%;
    width: auto;
    object-fit: contain;
    opacity: 0.6;       
}

/* --- CONTROLAR BANDERA Y SIGLA --- */
.destino-flag {
    width: 40px;        /* Bajamos un poquito la bandera para equilibrar visualmente */
    height: auto;
    margin-bottom: 4px; /* Margen controlado respecto al texto */
}

.destino-name {
    font-size: 0.72rem;
    font-weight: 700;
    color: #A89A90;
    letter-spacing: 2px;
    margin-top: 0;      /* Quitamos el margin-top auto para que no empuje */
}

    .destino-script {
        font-family: 'Playfair Display', serif;
        font-style: italic;
        font-size: 0.95rem;
        color: #1A1310;
        margin-bottom: 6px;
        font-weight: 400;
        line-height: 1.1;
    }

    .destino-flag {
        width: 40px;
        height: 26px;
        margin-bottom: 18px;
    }

    .destino-name {
        font-size: 0.75rem;
        font-weight: 700;
        color: #A89A90;
        letter-spacing: 2px;
        margin-top: auto;
    }

    .destinos-col-right {
        flex: 1;
