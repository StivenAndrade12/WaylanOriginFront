@page "/cita-semanal"

<div class="cita-page-wrapper">
    <!-- HERO / BANNER PRINCIPAL DE LA CITA SEMANAL -->
    <section class="cita-hero-section" style="background-image: linear-gradient(180deg, rgba(18, 12, 8, 0.88) 0%, rgba(18, 12, 8, 0.94) 100%), url('/imagenes/manoscafe.png');">
        <div class="cita-container">
            
            <!-- Botón Volver -->
            <div class="cita-back-navigation">
                <a href="/sostenibilidad" class="cita-back-btn">
                    <span class="arrow">←</span> VOLVER A SOSTENIBILIDAD
                </a>
            </div>

            <div class="cita-hero-grid">
                <div class="cita-hero-text-content">
                    <span class="cita-category-badge">CITA SEMANAL</span>
                    
                    <h1 class="cita-hero-title">
                        Cita Semanal:<br />
                        <span class="serif-gold-italic">Optimizando los procesos de secado en origen</span>
                    </h1>

                    <p class="cita-hero-subtitle">
                        Un espacio semanal para compartir experiencias, resolver retos y seguir construyendo juntos cafés de excelencia.
                    </p>

                    <!-- Meta Info: Fecha, Ubicación, Tiempo de lectura -->
                    <div class="cita-meta-info-row">
                        <div class="meta-item">
                            <svg class="meta-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                <line x1="3" y1="10" x2="21" y2="10"></line>
                            </svg>
                            <span>22 de mayo, 2024</span>
                        </div>

                        <div class="meta-item">
                            <svg class="meta-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                <circle cx="12" cy="10" r="3"></circle>
                            </svg>
                            <span>Finca La Esperanza, Tolima</span>
                        </div>

                        <div class="meta-item">
                            <svg class="meta-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                            <span>Tiempo de lectura: 6 min</span>
                        </div>
                    </div>
                </div>

                <div class="cita-hero-image-wrapper">
                    <div class="hero-image-frame">
                        <img src="/imagenes/espalda.png" alt="Productores en origen procesando café" class="hero-img" />
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- SECCIÓN INTERMEDIA: HISTORIA + RAZONES -->
    <section class="cita-main-details-section">
        <div class="cita-container">
            <div class="cita-two-columns-layout">
                
                <!-- Columna Izquierda: Texto de la Historia y Testimonio -->
                <div class="cita-story-column">
                    <h2 class="section-title-dark">Construimos calidad desde el origen</h2>
                    <div class="gold-divider-line"></div>

                    <p class="story-paragraph">
                        Cada semana visitamos a nuestras familias productoras para acompañar de cerca sus procesos y garantizar que cada café cumpla con los más altos estándares de calidad.
                    </p>
                    <p class="story-paragraph">
                        En esta cita, trabajamos de la mano con Don José Alberto para optimizar el secado del café, una etapa clave que define el perfil y la consistencia en taza.
                    </p>

                    <!-- Quote Block / Testimonio -->
                    <div class="quote-card">
                        <div class="quote-icon">“</div>
                        <blockquote class="quote-text">
                            El secado es donde el café cuenta su historia. Si lo hacemos bien, el resultado es un café limpio, dulce y con carácter.
                        </blockquote>
                        <div class="quote-author">
                            <img src="/imagenes/1f.png" alt="José Alberto Gómez" class="author-avatar" />
                            <div class="author-details">
                                <h5 class="author-name">JOSÉ ALBERTO GÓMEZ</h5>
                                <span class="author-title">Productor de café · Tolima, Colombia</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Columna Derecha: ¿Por qué es importante el secado? -->
                <div class="cita-reasons-column">
                    <div class="reasons-card-box">
                        <h3 class="reasons-title">¿Por qué es importante el secado?</h3>

                        <div class="reason-item">
                            <div class="reason-icon-wrapper">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="5"/>
                                    <line x1="12" y1="1" x2="12" y2="3"/>
                                    <line x1="12" y1="21" x2="12" y2="23"/>
                                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                                    <line x1="1" y1="12" x2="3" y2="12"/>
                                    <line x1="21" y1="12" x2="23" y2="12"/>
                                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                                </svg>
                            </div>
                            <div class="reason-content">
                                <h4>Desarrolla los sabores</h4>
                                <p>Un secado controlado resalta las notas dulces y afrutadas de cada origen.</p>
                            </div>
                        </div>

                        <div class="reason-item">
                            <div class="reason-icon-wrapper">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
                                </svg>
                            </div>
                            <div class="reason-content">
                                <h4>Evita defectos</h4>
                                <p>El control de humedad previene fermentaciones mefastas y sabores planos.</p>
                            </div>
                        </div>

                        <div class="reason-item">
                            <div class="reason-icon-wrapper">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/>
                                </svg>
                            </div>
                            <div class="reason-content">
                                <h4>Consistencia en taza</h4>
                                <p>Procesos estables garantizan perfiles de sabor confiables para nuestros clientes.</p>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- SECCIÓN: ASÍ OPTIMIZAMOS EL SECADO EN ORIGEN -->
    <section class="cita-optimization-section">
        <div class="cita-container">
            
            <div class="section-header-center">
                <div class="header-leaf-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#b89a5e" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 3.5 1 9.8a7 7 0 0 1-9 8.2Z"/>
                        <path d="M9 22v-4h4"/>
                    </svg>
                </div>
                <h2 class="title-center-serif">Así optimizamos el secado en origen</h2>
            </div>

            <div class="optimization-cards-grid">
                
                <div class="opt-card">
                    <div class="opt-card-image-box">
                        <img src="/imagenes/maduro.png" alt="Secado uniforme y controlado" />
                    </div>
                    <div class="opt-card-body">
                        <span class="opt-number">01.</span>
                        <div class="opt-info">
                            <h3>Secado uniforme y controlado</h3>
                            <p>Extendemos el café en camas elevadas y realizamos volteos constantes para asegurar un secado parejo.</p>
                        </div>
                    </div>
                </div>

                <div class="opt-card">
                    <div class="opt-card-image-box">
                        <img src="/imagenes/manoscafe.png" alt="Monitoreo de humedad" />
                    </div>
                    <div class="opt-card-body">
                        <span class="opt-number">02.</span>
                        <div class="opt-info">
                            <h3>Monitoreo de humedad</h3>
                            <p>Medimos constantemente la humedad del grano para alcanzar el punto ideal de conservación y calidad.</p>
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </section>

    <!-- SECCIÓN PRINCIPAL: NUESTRO PROCESO (LANDING HORIZONTAL SOLICITADA) -->
    <section class="proceso-landing-section">
        <div class="cita-container">
            
            <!-- Título Principal y Subtítulo Explicativo -->
            <div class="proceso-header">
                <span class="proceso-section-badge">ETAPAS DEL CAFÉ DE ESPECIALIDAD</span>
                <h2 class="proceso-section-title">Nuestro Proceso</h2>
                <p class="proceso-section-subtitle">
                    Descubre el viaje de nuestros granos desde la tierra hasta tu taza. Un proceso artesanal, metódico y lleno de pasión.
                </p>
                <div class="proceso-title-separator"></div>
            </div>

            <!-- Layout Horizontal Dividido en Tarjetas (Cards) -->
            <div class="proceso-cards-container">
                
                <!-- Tarjeta 1: Cultivo -->
                <div class="proceso-card fade-up-item">
                    <div class="card-step-badge">01</div>
                    <div class="card-icon-container">
                        <svg class="proceso-svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 22v-9"/>
                            <path d="M12 13C12 7.5 7.5 6 3 7c0 5.5 4.5 9 9 6Z"/>
                            <path d="M12 10C12 5.5 16.5 4 21 5c0 5.5-4.5 8-9 5Z"/>
                        </svg>
                    </div>
                    <h3 class="proceso-card-title">Cultivo</h3>
                    <p class="proceso-card-description">
                        Sembrado en suelos volcánicos de altura, respetando el ecosistema y la biodiversidad del origen.
                    </p>
                </div>

                <!-- Tarjeta 2: Recolección -->
                <div class="proceso-card fade-up-item">
                    <div class="card-step-badge">02</div>
                    <div class="card-icon-container">
                        <svg class="proceso-svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/>
                            <path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v6"/>
                            <path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8"/>
                            <path d="M18 8a2 2 0 0 1 2 2v4a8 8 0 0 1-16 0v-2"/>
                        </svg>
                    </div>
                    <h3 class="proceso-card-title">Recolección</h3>
                    <p class="proceso-card-description">
                        Cosecha 100% manual selectiva, tomando únicamente las cerezas en su madurez óptima.
                    </p>
                </div>

                <!-- Tarjeta 3: Lavado -->
                <div class="proceso-card fade-up-item">
                    <div class="card-step-badge">03</div>
                    <div class="card-icon-container">
                        <svg class="proceso-svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
                            <path d="M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" opacity="0.4"/>
                        </svg>
                    </div>
                    <h3 class="proceso-card-title">Lavado</h3>
                    <p class="proceso-card-description">
                        Despulpado cuidadoso y remoción del mucílago con agua de manantial limpia y recirculada.
                    </p>
                </div>

                <!-- Tarjeta 4: Secado -->
                <div class="proceso-card fade-up-item">
                    <div class="card-step-badge">04</div>
                    <div class="card-icon-container">
                        <svg class="proceso-svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="4"/>
                            <path d="M12 2v2"/>
                            <path d="M12 20v2"/>
                            <path d="m4.93 4.93 1.41 1.41"/>
                            <path d="m17.66 17.66 1.41 1.41"/>
                            <path d="M2 12h2"/>
                            <path d="M20 12h2"/>
                            <path d="m6.34 17.66-1.41 1.41"/>
                            <path d="m19.07 4.93-1.41 1.41"/>
                        </svg>
                    </div>
                    <h3 class="proceso-card-title">Secado</h3>
                    <p class="proceso-card-description">
                        Secado al sol en marquesinas elevadas con flujo de aire constante hasta el 10-12% de humedad.
                    </p>
                </div>

                <!-- Tarjeta 5: Tostión -->
                <div class="proceso-card fade-up-item">
                    <div class="card-step-badge">05</div>
                    <div class="card-icon-container">
                        <svg class="proceso-svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 3.5z"/>
                        </svg>
                    </div>
                    <h3 class="proceso-card-title">Tostión</h3>
                    <p class="proceso-card-description">
                        Tueste artesanal en pequeños lotes para perfilar y resaltar los atributos sensoriales del origen.
                    </p>
                </div>

            </div>

        </div>
    </section>

    <!-- BANNER DE CIERRE Y BOTÓN "VER PRÓXIMA CITA" -->
    <section class="cita-callout-section">
        <div class="cita-container">
            <div class="callout-box">
                <div class="callout-content">
                    <div class="callout-illustration">
                        <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="#b89a5e" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 3.5 1 9.8a7 7 0 0 1-9 8.2Z"/>
                            <path d="M9 22v-4h4"/>
                        </svg>
                    </div>
                    <div class="callout-text">
                        <h3>Seguimos aprendiendo, creciendo y construyendo juntos</h3>
                        <p>Estas conversaciones semanales nos permiten compartir conocimientos, resolver desafíos y seguir elevando la calidad de nuestros cafés, desde la finca hasta tu taza.</p>
                    </div>
                </div>

                <div class="callout-action">
                    <a href="/sostenibilidad" class="btn-callout">
                        VER PRÓXIMA CITA <span class="arrow-symbol">→</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- BARRA INFERIOR DE IMPACTO Y ESTADÍSTICAS -->
    <footer class="cita-impact-footer">
        <div class="cita-container">
            <div class="impact-stats-row">
                
                <div class="impact-stat-item">
                    <div class="impact-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                    </div>
                    <div class="impact-data">
                        <span class="impact-number">+150</span>
                        <p class="impact-label">Familias beneficiadas de forma directa</p>
                    </div>
                </div>

                <div class="impact-divider"></div>

                <div class="impact-stat-item">
                    <div class="impact-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <path d="M2 12h20"></path>
                            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                        </svg>
                    </div>
                    <div class="impact-data">
                        <span class="impact-number">100%</span>
                        <p class="impact-label">Trazabilidad garantizada desde la finca</p>
                    </div>
                </div>

                <div class="impact-divider"></div>

                <div class="impact-stat-item">
                    <div class="impact-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20.42 4.58a5.4 5.4 0 0 0-7.65 0l-.77.78-.77-.78a5.4 5.4 0 0 0-7.65 7.65l.77.78L12 21.35l7.65-7.65.77-.78a5.4 5.4 0 0 0 0-7.65z"></path>
                        </svg>
                    </div>
                    <div class="impact-data">
                        <span class="impact-number">0%</span>
                        <p class="impact-label">Intermediarios en la cadena de valor</p>
                    </div>
                </div>

            </div>
        </div>
    </footer>
</div>
