@code {
    private HashSet<string> SelectedFormats = new();
    private HashSet<string> SelectedProfiles = new();
    private HashSet<string> SelectedMethods = new();
    private int SelectedIntensity = 0;
    private int MaxPrice = 150000;

    // Sidebar expansion collapse states
    private bool isTypeExpanded = true;
    private bool isProfileExpanded = true;
    private bool isIntensityExpanded = true;
    private bool isMethodExpanded = true;

    private List<Product> AllProducts = new();
    private List<Category> AllCategories = new();
    private List<Note> AllNotes = new();

    protected override async Task OnInitializedAsync()
    {
        AllProducts = await ApiService.GetProductosActivosAsync();
        AllCategories = await ApiService.GetCategoriasActivasAsync();
        AllNotes = await ApiService.GetNotasAsync();
        CartState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        CartState.OnChange -= StateHasChanged;
    }

    private IEnumerable<Product> GetFilteredProducts()
    {
        var query = AllProducts.AsEnumerable();

        if (SelectedFormats.Any())
        {
            query = query.Where(p => SelectedFormats.Contains(p.Formato));
        }

        if (SelectedProfiles.Any())
        {
            query = query.Where(p => SelectedProfiles.Contains(p.PerfilSabor));
        }

        if (SelectedMethods.Any())
        {
            query = query.Where(p => SelectedMethods.Contains(p.MetodoRecomendado));
        }

        if (SelectedIntensity > 0)
        {
            query = query.Where(p => p.Intensidad == SelectedIntensity);
        }

        query = query.Where(p => p.Precio <= MaxPrice);

        return query;
    }

    private void ToggleFormatFilter(string format)
    {
        if (SelectedFormats.Contains(format))
            SelectedFormats.Remove(format);
        else
            SelectedFormats.Add(format);
    }

    private void ToggleProfileFilter(string profile)
    {
        if (SelectedProfiles.Contains(profile))
            SelectedProfiles.Remove(profile);
        else
            SelectedProfiles.Add(profile);
    }

    private void ToggleMethodFilter(string method)
    {
        if (SelectedMethods.Contains(method))
            SelectedMethods.Remove(method);
        else
            SelectedMethods.Add(method);
    }

    private void FilterByIntensity(int intensity)
    {
        SelectedIntensity = intensity;
    }

    private void ClearIntensityFilter()
    {
        SelectedIntensity = 0;
    }

    private void FilterByCategory(string categoryName)
    {
        SelectedFormats.Clear();
        SelectedFormats.Add(categoryName);
    }

    private void ClearAllFilters()
    {
        SelectedFormats.Clear();
        SelectedProfiles.Clear();
        SelectedMethods.Clear();
        SelectedIntensity = 0;
        MaxPrice = 150000;
    }

    private int GetFormatCount(string format) => AllProducts.Count(p => p.Formato == format);
    private int GetProfileCount(string profile) => AllProducts.Count(p => p.PerfilSabor == profile);
    private int GetMethodCount(string method) => AllProducts.Count(p => p.MetodoRecomendado == method);

    private void ToggleFavorite(Product p)
    {
        p.IsFavorite = !p.IsFavorite;
    }

    private void AgregarAlCarrito(Product p)
    {
        CartState.AddProduct(p);
    }

    private void ToggleTypeContent() => isTypeExpanded = !isTypeExpanded;
    private void ToggleProfileContent() => isProfileExpanded = !isProfileExpanded;
    private void ToggleIntensityContent() => isIntensityExpanded = !isIntensityExpanded;
    private void ToggleMethodContent() => isMethodExpanded = !isMethodExpanded;

    private string GetProductImage(Product p)
    {
        if (string.IsNullOrEmpty(p.ImagenUrl)) return "/images/coffee_bag_generic.png";
        if (p.ImagenUrl.StartsWith("/uploads/")) return "http://localhost:5074" + p.ImagenUrl;
        return p.ImagenUrl;
    }
}

