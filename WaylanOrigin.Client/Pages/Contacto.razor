@page "/contacto"

<section class="contacto-section">
    <!-- Ilustración de Hoja/Rama de Café de Fondo (Arriba a la derecha) -->
    <div class="coffee-branch-bg"></div>

    <div class="contacto-container">
        
       <!-- Encabezado Centrado -->
      <div class="contacto-header text-center" style="text-align: center; display: flex; flex-direction: column; align-items: center;">
            <p class="subtitle-gold" style="text-align: center; margin-bottom: 8px;">ESTAMOS PARA TI</p>
              <h1 class="title-serif" style="text-align: center; margin-bottom: 12px;">Contáctanos</h1>
    
                <!-- Divisor centrado -->
              <div class="divider-gold" style="margin: 0 auto 16px auto;"></div>
    
               <p class="description-text" style="text-align: center;">
               Estamos aquí para ayudarte. Escríbenos y te responderemos<br class="d-none d-md-block" /> lo antes posible.
                  </p>
       </div>

        <!-- Grid Principal de Contacto -->
        <div class="contacto-grid">
            
            <!-- TARJETA IZQUIERDA: Información de Contacto -->
            <div class="info-card">
                <h2 class="card-title-serif">Información de contacto</h2>
                <div class="small-divider-gold"></div>

                <div class="info-list">
                    <!-- Dirección -->
                    <div class="info-item">
                        <div class="icon-wrapper">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C39A58" stroke-width="1.8">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                <circle cx="12" cy="10" r="3"></circle>
                            </svg>
                        </div>
                        <div class="info-text">
                            <h3>Dirección</h3>
                            <p>Finca La Esperanza, Vereda San Antonio<br />Tolima, Colombia</p>
                        </div>
                    </div>

                    <!-- Teléfono -->
                    <div class="info-item">
                        <div class="icon-wrapper">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C39A58" stroke-width="1.8">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                            </svg>
                        </div>
                        <div class="info-text">
                            <h3>Teléfono</h3>
                            <p>+57 310 123 4567</p>
                        </div>
                    </div>

                    <!-- Correo electrónico -->
                    <div class="info-item">
                        <div class="icon-wrapper">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C39A58" stroke-width="1.8">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                                <polyline points="22,6 12,13 2,6"></polyline>
                            </svg>
                        </div>
                        <div class="info-text">
                            <h3>Correo electrónico</h3>
                            <p>hola@waylanorigin.com</p>
                        </div>
                    </div>

                    <!-- Horario de atención -->
                    <div class="info-item">
                        <div class="icon-wrapper">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C39A58" stroke-width="1.8">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                        </div>
                        <div class="info-text">
                            <h3>Horario de atención</h3>
                            <p>Lunes a Viernes: 8:00 a.m. - 5:00 p.m.</p>
                            <p>Sábados: 8:00 a.m. - 12:00 m.</p>
                        </div>
                    </div>
                </div>

                <!-- Redes Sociales -->
                <div class="social-icons">
                    <a href="#" aria-label="Instagram">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                    </a>
                    <a href="#" aria-label="Facebook">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                    </a>
                    <a href="#" aria-label="WhatsApp">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                    </a>
                </div>
            </div>

            <!-- TARJETA DERECHA: Formulario de Mensaje -->
            <div class="form-card">
                <h2 class="card-title-serif">Envíanos un mensaje</h2>
                <div class="small-divider-gold"></div>

                <EditForm Model="@contactModel" OnValidSubmit="@HandleSubmit" class="form-body" style="display: flex; flex-direction: column; gap: 16px;">
                    <DataAnnotationsValidator />

                    <!-- Fila horizontal para Nombre y Correo con separación (gap) -->
                    <div class="form-row" style="display: flex; gap: 16px;">
                        <div class="form-group" style="flex: 1;">
                            <InputText class="form-control-custom" @bind-Value="contactModel.Name" placeholder="Nombre completo" style="width: 100%;" />
                            <ValidationMessage For="@(() => contactModel.Name)" />
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <InputText class="form-control-custom" @bind-Value="contactModel.Email" placeholder="Correo electrónico" style="width: 100%;" />
                            <ValidationMessage For="@(() => contactModel.Email)" />
                        </div>
                    </div>

                    <!-- Asunto -->
                    <div class="form-group">
                        <InputText class="form-control-custom" @bind-Value="contactModel.Subject" placeholder="Asunto" style="width: 100%;" />
                        <ValidationMessage For="@(() => contactModel.Subject)" />
                    </div>

                    <!-- Mensaje -->
                    <div class="form-group">
                        <InputTextArea class="form-control-custom textarea-custom" rows="5" @bind-Value="contactModel.Message" placeholder="Mensaje" style="width: 100%;" />
                        <ValidationMessage For="@(() => contactModel.Message)" />
                    </div>

                    <!-- Botón -->
                    <button type="submit" class="btn-submit-black" disabled="@isSubmitting" style="margin-top: 8px;">
                        <span>@(isSubmitting ? "ENVIANDO..." : "ENVIAR MENSAJE")</span>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C39A58" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </button>

                    @if (submitted)
                    {
                        <div class="success-msg">
                            ¡Mensaje enviado con éxito! Te responderemos muy pronto.
                        </div>
                    }
                </EditForm>
            </div>

        </div>
    </div>

    <!-- BANNER INFERIOR DE BENEFICIOS (Negro) -->
    <div class="bottom-benefits-bar">
        <div class="benefits-container">
            <!-- Beneficio 1 -->
            <div class="benefit-item">
                <div class="benefit-icon">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#C39A58" stroke-width="1.5">
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path>
                    </svg>
                </div>
                <div class="benefit-text">
                    <h4>Café de origen</h4>
                    <p>De nuestras fincas<br />a tu taza.</p>
                    <div class="mini-line-gold"></div>
                </div>
            </div>

            <!-- Beneficio 2 -->
            <div class="benefit-item">
                <div class="benefit-icon">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#C39A58" stroke-width="1.5">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                    </svg>
                </div>
                <div class="benefit-text">
                    <h4>Relación directa</h4>
                    <p>Trabajamos de la mano con<br />nuestros productores.</p>
                    <div class="mini-line-gold"></div>
                </div>
            </div>

            <!-- Beneficio 3 -->
            <div class="benefit-item">
                <div class="benefit-icon">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#C39A58" stroke-width="1.5">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                    </svg>
                </div>
                <div class="benefit-text">
                    <h4>Sostenibilidad</h4>
                    <p>Cuidamos la tierra para<br />un futuro mejor.</p>
                    <div class="mini-line-gold"></div>
                </div>
            </div>

            <!-- Beneficio 4 -->
            <div class="benefit-item">
                <div class="benefit-icon">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#C39A58" stroke-width="1.5">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                        <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                        <line x1="12" y1="22.08" x2="12" y2="12"></line>
                    </svg>
                </div>
                <div class="benefit-text">
                    <h4>Envíos a todo el país</h4>
                    <p>Llevamos nuestro café<br />hasta tu puerta.</p>
                    <div class="mini-line-gold"></div>
                </div>
            </div>
        </div>
    </div>
</section>

@using System.ComponentModel.DataAnnotations

@code {
    private FormularioContactoModel contactModel = new();
    private bool isSubmitting = false;
    private bool submitted = false;

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        await Task.Delay(1200); // Simulación de procesamiento
        isSubmitting = false;
        submitted = true;
        contactModel = new();
    }

    public class FormularioContactoModel
    {
        [Required(ErrorMessage = "Campo requerido")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Campo requerido")]
        [EmailAddress(ErrorMessage = "Correo no válido")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Campo requerido")]
        public string Subject { get; set; } = string.Empty;

        [Required(ErrorMessage = "Campo requerido")]
        public string Message { get; set; } = string.Empty;
    }
}