@page "/sostenibilidad"

<section class="sost-hero" style="background-image: linear-gradient(90deg, rgba(18, 12, 8, 0.96) 25%, rgba(18, 12, 8, 0.8) 55%, rgba(18, 12, 8, 0.45) 100%), url('/imagenes/camp.png');">
    <div class="sost-container hero-layout">
        <div class="sost-hero-content">
            <div class="sost-badge-row">
                <span class="sost-tag">SOSTENIBILIDAD</span>
                <span class="badge-line-decorator"></span>
            </div>

            <h1 class="sost-main-title">
                Sostenibilidad:<br />
                <span class="serif-italic-gold">café con propósito</span>
            </h1>

            <p class="sost-description">
                Conectamos directamente con el origen. Trabajamos de la mano con nuestros productores para garantizar un café excepcional mientras cuidamos la tierra y aseguramos la prosperidad de sus familias.
            </p>

            <div class="sost-hero-actions">
                <a href="#contenido-sostenibilidad" class="btn-gold">CONOCER MÁS <span class="arrow-symbol">→</span></a>
                <a href="/productores" class="btn-outline">NUESTRAS ALIANZAS</a>
            </div>
        </div>
    </div>
</section>

<!-- ID para ancla del botón conocer más -->
<div id="contenido-sostenibilidad"></div>

<!-- Navegación de Pestañas (Tabs) -->
<section class="sost-tabs-section">
    <div class="sost-tabs-container">
        <div class="sost-tabs-list">
            <button class="sost-tab-item @(activeTab == 1 ? "active" : "")" @onclick="() => SetActiveTab(1)" type="button">
                <svg class="tab-svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/>
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                    <line x1="12" x2="12" y1="19" y2="22"/>
                </svg>
                <span class="tab-label">Hablemos de Café</span>
            </button>
            <button class="sost-tab-item @(activeTab == 2 ? "active" : "")" @onclick="() => SetActiveTab(2)" type="button">
                <svg class="tab-svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m11 17 2 2a1 1 0 0 0 1.4 0l4-4a1 1 0 0 0 0-1.4l-2.6-2.6a1 1 0 0 0-1.4 0L13 13"/>
                    <path d="m13 13-2-2a1 1 0 0 0-1.4 0l-4 4a1 1 0 0 0 0 1.4l2.6 2.6a1 1 0 0 0 1.4 0L11 17"/>
                    <path d="m15 9-3-3a1 1 0 0 0-1.4 0l-4 4a1 1 0 0 0 0 1.4"/>
                    <path d="m9 15 3 3a1 1 0 0 0 1.4 0l4-4a1 1 0 0 0 0-1.4"/>
                </svg>
                <span class="tab-label">Origen y Relación</span>
            </button>
            <button class="sost-tab-item @(activeTab == 3 ? "active" : "")" @onclick="() => SetActiveTab(3)" type="button">
                <svg class="tab-svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 3.5 1 9.8a7 7 0 0 1-9 8.2Z"/>
                    <path d="M9 22v-4h4"/>
                </svg>
                <span class="tab-label">Cuidado de la Tierra</span>
            </button>
            <button class="sost-tab-item @(activeTab == 4 ? "active" : "")" @onclick="() => SetActiveTab(4)" type="button">
                <svg class="tab-svg-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 3h12"/>
                    <path d="M8 3v4.3a4 4 0 0 1-.72 2.22l-4.56 6.84A2 2 0 0 0 4.4 19.33h15.2a2 2 0 0 0 1.68-2.97l-4.56-6.84A4 4 0 0 1 16 7.3V3"/>
                </svg>
                <span class="tab-label">Calidad</span>
            </button>
        </div>
        <div class="active-tab-line" style="left: @(GetTabLinePosition())%;"></div>
    </div>
</section>

<!-- Contenido Dinámico de las Pestañas -->
<div class="sost-content-wrapper">
    <div class="sost-container">

        @if (activeTab == 1)
        {
            <div class="tab-pane fade-in">
                <div class="tab-message-container text-center">
                    <p class="tab-message-text">"Nuestra cita semanal en el origen: impulsando programas reales junto a quienes cultivan tu taza."</p>
                </div>

                <div class="sost-tab-grid grid-2col">
                    <!-- Columna Izquierda: Tarjeta de la Bitácora -->
                    <div class="sost-card-wrapper">
                        <div class="sost-blog-card">
                            <div class="sost-blog-card-img" style="background-image: url('/imagenes/linea2.png');">
                                <span class="sost-card-badge">CITA SEMANAL</span>
                            </div>
                            <div class="sost-blog-card-body">
                                <span class="sost-card-tag">PROGRAMA ACTUAL</span>
                                <h3 class="sost-card-title">Hablemos de café con nuestros productores</h3>
                                <p class="sost-card-text">Un espacio semanal para compartir historias, retos y aprendizajes desde el origen.</p>
                                <a href="/cita-semanal" class="sost-card-link">VER PROGRAMA <span class="arrow-symbol">→</span></a>
                            </div>
                        </div>
                    </div>

                    <!-- Columna Derecha: Testimonio -->
                    <div class="sost-testimonio-wrapper">
                        <div class="sost-quote-icon">“</div>
                        <blockquote class="sost-testimonial-quote">
                            Para nosotros, cultivar café es más que un trabajo, es cuidar nuestra tierra y dejar un futuro mejor para nuestras familias y nuestra comunidad.
                        </blockquote>
                        <div class="sost-testimonial-author">
                            <img src="/imagenes/ñ1.png" alt="José Alberto Gómez" class="sost-author-avatar" />
                            <div class="sost-author-info">
                                <h5 class="sost-author-name">JOSÉ ALBERTO GÓMEZ</h5>
                                <p class="sost-author-role">Productor de café</p>
                                <p class="sost-author-location">Tolima, Colombia</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Métricas de Impacto específicas de la Tab (Estilo Foto 2) -->
                <div class="sost-metrics-container">
                    <span class="sost-metrics-tag">NUESTRO IMPACTO</span>
                    <div class="sost-metrics-grid">
                        <div class="sost-metric-card">
                            <div class="sost-metric-icon-box">
                                <img src="/logotipo/logo1.png" alt="Familias" />
                            </div>
                            <h3 class="sost-metric-value">+150</h3>
                            <h4 class="sost-metric-title">Familias beneficiadas</h4>
                            <p class="sost-metric-desc">Relaciones de largo plazo que generan bienestar y desarrollo.</p>
                        </div>

                        <div class="sost-metric-divider"></div>

                        <div class="sost-metric-card">
                            <div class="sost-metric-icon-box">
                                <img src="/logotipo/logo2.png" alt="Trazabilidad" />
                            </div>
                            <h3 class="sost-metric-value">100%</h3>
                            <h4 class="sost-metric-title">Trazabilidad</h4>
                            <p class="sost-metric-desc">Desde la finca hasta tu taza, con transparencia total.</p>
                        </div>

                        <div class="sost-metric-divider"></div>

                        <div class="sost-metric-card">
                            <div class="sost-metric-icon-box">
                                <img src="/logotipo/logo3.png" alt="Intermediarios" />
                            </div>
                            <h3 class="sost-metric-value">0%</h3>
                            <h4 class="sost-metric-title">Intermediarios</h4>
                            <p class="sost-metric-desc">Relación directa y justa con nuestros productores.</p>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (activeTab == 2)
        {
            <div class="tab-pane fade-in">
                <div class="tab-message-container text-center">
                    <p class="tab-message-text">"Trazabilidad total y comercio justo desde la raíz."</p>
                </div>

                <!-- Fila Superior: Relación directa y Cercanía (Estilo Foto 1) -->
                <div class="sost-tab-grid grid-2col" style="margin-bottom: 70px;">
                    <!-- Columna Izquierda: Tarjeta Relación Directa -->
                    <div class="sost-direct-card" style="background-image: linear-gradient(to top, rgba(0,0,0,0.92) 20%, rgba(0,0,0,0.5) 60%, rgba(0,0,0,0.25) 100%), url('/imagenes/w1.png');">
                        <div class="sost-direct-card-content">
                            <p class="sost-direct-subtitle">Nuestro compromiso en el origen:</p>
                            <h3 class="sost-direct-title">Relación directa</h3>
                            <p class="sost-direct-text">
                                Compramos directamente a las familias productoras, sin intermediarios. Garantizamos un pago justo que reconoce su esfuerzo y dedicación. Construimos alianzas de por vida, basadas en confianza y respeto mutuo.
                            </p>
                        </div>
                    </div>

                    <!-- Columna Derecha: Texto Cercanía y Transparencia -->
                    <div class="sost-transparency-card">
                        <div class="sost-transparency-text">
                            <h3 class="sost-transparency-title">Cercanía y Transparencia</h3>
                            <span class="title-underline"></span>
                            <p class="sost-transparency-desc">
                                Creemos en relaciones reales, basadas en la confianza y el respeto. Por eso estamos presentes en el origen, escuchamos, acompañamos y trabajamos junto a cada productor para ofrecer un café con propósito, trazable y de la más alta calidad.
                            </p>
                        </div>
                        <div class="sost-transparency-drawing">
                            <!-- SVG lineal decorativo de una rama de café -->
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 180" class="coffee-branch-svg">
                                <path d="M60,180 Q55,120 40,80 Q30,50 60,10" fill="none" stroke="#B89A5E" stroke-width="1.5" />
                                <!-- Hoja 1 -->
                                <path d="M48,100 C30,95 20,80 35,70 C45,65 52,80 48,100 Z" fill="none" stroke="#B89A5E" stroke-width="1.2" />
                                <line x1="48" y1="100" x2="33" y2="82" stroke="#B89A5E" stroke-width="1" />
                                <!-- Hoja 2 -->
                                <path d="M55,60 C75,55 85,40 70,30 C60,25 50,45 55,60 Z" fill="none" stroke="#B89A5E" stroke-width="1.2" />
                                <line x1="55" y1="60" x2="68" y2="42" stroke="#B89A5E" stroke-width="1" />
                                <!-- Cerezas de Café (Cherries) -->
                                <circle cx="48" cy="85" r="4.5" fill="#8C2424" />
                                <circle cx="53" cy="88" r="4.5" fill="#A83232" />
                                <circle cx="45" cy="91" r="4" fill="#B89A5E" />
                                <circle cx="56" cy="55" r="4.5" fill="#8C2424" />
                                <circle cx="51" cy="50" r="4" fill="#A83232" />
                            </svg>
                        </div>
                    </div>
                </div>

                <!-- Sección Central: Proceso de Relación -->
                <div class="sost-process-section">
                    <div class="sost-center-header">
                        <div class="delicate-separator">
                            <span class="sep-line"></span>
                            <span class="sep-dot"></span>
                            <span class="sep-line"></span>
                        </div>
                        <h3 class="sost-process-main-title">Nuestro proceso con los productores en el origen</h3>
                    </div>

                    <div class="sost-process-timeline">
                        <div class="process-connecting-line"></div>

                        <div class="process-node">
                            <div class="process-node-number">01</div>
                            <div class="process-node-icon-box">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="#B89A5E" class="bi bi-house-door" viewBox="0 0 16 16">
                                    <path d="M8.354 1.146a.5.5 0 0 0-.708 0l-6 6A.5.5 0 0 0 1.5 7.5v7a.5.5 0 0 0 .5.5h4.5a.5.5 0 0 0 .5-.5v-4h2v4a.5.5 0 0 0 .5.5H14a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-.146-.354L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293L8.354 1.146ZM2.5 14V7.707l5.5-5.5 5.5 5.5V14H10v-4a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5v4H2.5Z"/>
                                </svg>
                            </div>
                            <h4 class="process-node-title">Visita y Acercamiento en Finca</h4>
                            <p class="process-node-text">Conectamos directamente en su territorio para conocer sus necesidades y las condiciones de su café.</p>
                        </div>

                        <div class="process-node">
                            <div class="process-node-number">02</div>
                            <div class="process-node-icon-box">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="#B89A5E" class="bi bi-people" viewBox="0 0 16 16">
                                    <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1h8Zm-7.978-1A.261.261 0 0 1 7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002a.274.274 0 0 1-.014.002H7.022ZM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0ZM6.936 9.28a5.88 5.88 0 0 0-1.23-.247A7.35 7.35 0 0 0 5 9c-4 0-5 3-5 4 0 .667.333 1 1 1h4.216A2.238 2.238 0 0 1 5 13c0-1.01.377-2.047 1.09-2.904.243-.294.526-.569.846-.816ZM6 2a2 2 0 1 0 0 4 2 2 0 0 0 0-4Zm3.5 3a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                                </svg>
                            </div>
                            <h4 class="process-node-title">Acompañamiento y Proceso de Calidad</h4>
                            <p class="process-node-text">Trabajamos de la mano en sus fincas para asegurar que el café cumpla con las condiciones de calidad que el cliente exige.</p>
                        </div>

                        <div class="process-node">
                            <div class="process-node-number">03</div>
                            <div class="process-node-icon-box">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="#B89A5E" class="bi bi-handshake" viewBox="0 0 16 16">
                                    <path d="M12.267 11.236a.5.5 0 0 0-.467-.263H11v-1a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v1H4.2a.5.5 0 0 0-.467.263l-2.5 5a.5.5 0 0 0 .447.737H14.32a.5.5 0 0 0 .447-.737l-2.5-5zM5 10a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v1H5v-1zm-2.736 6L4.5 11.528 5.764 14H10.24l1.264-2.472L13.736 16H2.264z"/>
                                </svg>
                            </div>
                            <h4 class="process-node-title">Alianza de Largo Plazo</h4>
                            <p class="process-node-text">Establecemos una relación de confianza mutua, asegurando compras directas y estabilidad para sus familias.</p>
                        </div>
                    </div>
                </div>

                <!-- Métricas de Impacto al Final de la pestaña (Estilo Foto 1) -->
                <div class="sost-metrics-strip dark-bg">
                    <div class="strip-item">
                        <img src="/logotipo/logo1.png" class="strip-icon" alt="Familias" />
                        <div class="strip-info">
                            <span class="strip-number">+150</span>
                            <span class="strip-label">Familias beneficiadas de forma directa</span>
                        </div>
                    </div>
                    <div class="strip-divider"></div>
                    <div class="strip-item">
                        <img src="/logotipo/logo2.png" class="strip-icon" alt="Trazabilidad" />
                        <div class="strip-info">
                            <span class="strip-number">100%</span>
                            <span class="strip-label">Café con trazabilidad garantizada desde la finca</span>
                        </div>
                    </div>
                    <div class="strip-divider"></div>
                    <div class="strip-item">
                        <img src="/logotipo/logo3.png" class="strip-icon" alt="Intermediarios" />
                        <div class="strip-info">
                            <span class="strip-number">0%</span>
                            <span class="strip-label">Intermediarios en la cadena de valor</span>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (activeTab == 3)
        {
            <div class="tab-pane fade-in">
                <div class="tab-message-container text-center">
                    <p class="tab-message-text">"Nutrimos la tierra hoy para asegurar la cosecha del mañana."</p>
                </div>

                <div class="sost-tab-grid grid-2col">
                    <!-- Columna Izquierda: Plan de Fertilización -->
                    <div class="sost-card-wrapper">
                        <div class="sost-fertilizacion-card" style="background-image: linear-gradient(135deg, rgba(47, 25, 14, 0.95) 40%, rgba(47, 25, 14, 0.75) 100%), url('/imagenes/manoscafe.png');">
                            <span class="sost-card-tag-gold">PLAN TÉCNICO</span>
                            <h3 class="sost-fertilizacion-title">Plan de Fertilización Responsable</h3>
                            <p class="sost-fertilizacion-text">
                                Asesoramos técnicamente a cada productor para realizar análisis de suelos periódicos y aplicar planes de nutrición equilibrados.
                            </p>
                            <p class="sost-fertilizacion-text">
                                De esta forma, evitamos la sobre-fertilización química, protegemos el micro-ecosistema del suelo y prevenimos la contaminación de fuentes de agua locales, logrando un cultivo saludable y de alto rendimiento.
                            </p>
                            <div class="soil-leaf-graphic">
                                <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="#B89A5E" class="bi bi-droplet-half" viewBox="0 0 16 16">
                                    <path fill-rule="evenodd" d="M7.21.8C7.69.295 8 0 8 0c.133.193.308.452.5.758a90.123 90.123 0 0 1 1.258 2.099A27.108 27.108 0 0 1 11.44 6.57C12.754 8.79 13 10.3 13 11a5 5 0 0 1-10 0c0-.7.246-2.21 1.56-4.43.435-.733.914-1.502 1.393-2.27.48-.767.962-1.536 1.257-2.1H7.21zm.67.78-.03.042c-.276.438-.726 1.217-1.192 1.963C6.182 4.41 5.687 5.2 5.26 5.923 4.137 7.82 4 9.07 4 11a4 4 0 0 0 7.864.935l-.01-.013c-.015-.027-.042-.072-.081-.137-.08-.131-.19-.344-.306-.632-.228-.567-.47-1.397-.47-2.653 0-1.077-.243-2.146-.665-3.14-.383-.896-.783-1.635-.97-1.956L8 1.93l-.12.35z"/>
                                </svg>
                            </div>
                        </div>
                    </div>

                    <!-- Columna Derecha: Prácticas Agroecológicas -->
                    <div class="sost-practices-container">
                        <h3 class="sost-practices-main-title">Prácticas Agroecológicas</h3>
                        <p class="sost-practices-intro">Implementamos técnicas que protegen el equilibrio biológico del cafetal y reducen la huella ambiental.</p>

                        <div class="sost-practice-item">
                            <div class="sost-practice-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#B89A5E" class="bi bi-shield-check" viewBox="0 0 16 16">
                                    <path d="M5.338 1.59a61.44 61.44 0 0 0-2.837.856.481.481 0 0 0-.328.39c-.554 4.157.726 7.19 2.253 9.188a10.725 10.725 0 0 0 2.287 2.233c.346.244.652.42.893.533.12.057.218.095.293.118a.55.55 0 0 0 .101.025.615.615 0 0 0 .1-.025c.076-.023.174-.061.294-.118.24-.113.547-.29.893-.533a10.726 10.726 0 0 0 2.287-2.233c1.527-1.997 2.807-5.031 2.253-9.188a.48.48 0 0 0-.328-.39c-.651-.213-1.75-.56-2.837-.855C9.552 1.29 8.531 1.067 8 1.067c-.53 0-1.552.223-2.662.524zM5.072.56C6.157.265 7.31 0 8 0s1.843.265 2.928.56c1.11.3 2.229.655 2.887.87a1.54 1.54 0 0 1 1.044 1.262c.596 4.477-.787 7.794-2.465 9.99a11.775 11.775 0 0 1-2.517 2.453 7.159 7.159 0 0 1-1.048.625c-.28.132-.581.24-.829.24s-.548-.108-.829-.24a7.158 7.158 0 0 1-1.048-.625 11.777 11.777 0 0 1-2.517-2.453C1.928 10.487.545 7.169 1.141 2.692A1.54 1.54 0 0 1 2.185 1.43 62.456 62.456 0 0 1 5.072.56z"/>
                                    <path d="M10.854 5.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 7.793l2.646-2.647a.5.5 0 0 1 .708 0z"/>
                                </svg>
                            </div>
                            <div class="sost-practice-content">
                                <h4 class="sost-practice-title">Conservación del Suelo</h4>
                                <p class="sost-practice-text">Uso de coberturas nobles e intercalado de árboles de sombra para evitar la erosión del terreno montañoso.</p>
                            </div>
                        </div>

                        <div class="sost-practice-item">
                            <div class="sost-practice-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#B89A5E" class="bi bi-water" viewBox="0 0 16 16">
