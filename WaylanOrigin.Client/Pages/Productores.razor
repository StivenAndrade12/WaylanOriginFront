@page "/Productores"
@inject IJSRuntime JSRuntime

<section class="productores-section">
    <div class="container">
        <!-- Encabezado de la sección -->
        <div class="header-content">
            <span class="subtitle">PRODUCTORES ALIADOS</span>
            <h1 class="title">Trabajamos junto a organizaciones que impulsan el café de origen.</h1>

            <!-- Decorador premium: líneas + hoja -->
            <div class="decoracion-titulo">
                <span class="linea"></span>
                <span class="icono-hoja">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 3.5 1 9.2a7 7 0 0 1-14 3.1c0-1.5 1-3.5 3-4"></path>
                        <path d="M19 2c-2.26 4.33-5.27 7.14-8 10"></path>
                    </svg>
                </span>
                <span class="linea"></span>
            </div>

            <p class="description">
                Conoce a nuestras organizaciones aliadas, comprometidas con la calidad, la sostenibilidad y el bienestar de los caficultores.
            </p>
        </div>

        <!-- Contenedor de tarjetas -->
        <div class="cards-grid">

            <!-- Tarjeta 1: FAMYCAFE -->
            <div class="org-card">
                <div class="card-image-placeholder">
                    <img src="/logotipo/fcf.png" alt="FAMYCAFE Logo" />
                </div>
                <div class="card-body">
                    <h3>FAMYCAFE</h3>
                    <p>Asociación de familias cafeteras comprometidas con la calidad y la sostenibilidad.</p>
                    <a href="/organizacion/famycafe" class="btn-ver">
                     Ver organización <span class="arrow">→</span>
                    </a>
                    

                </div>
            </div>

            <!-- Tarjeta 2: TRES NEVADOS -->
            <div class="org-card">
                <div class="card-image-placeholder">
                    <img src="/logotipo/trn.png" alt="Tres Nevados Logo" />
                </div>
                <div class="card-body">
                    <h3>TRES NEVADOS</h3>
                    <p>Trabajamos por el desarrollo del caficultor y la protección de nuestra región.</p>
                    <a href="/organizacion/tres-nevados" class="btn-ver">
                      Ver organización <span class="arrow">→</span>
                    </a>


                </div>
            </div>

            <!-- Tarjeta 3: OTRAS ORGANIZACIONES -->
            

        </div> <!-- Cierre correcto de cards-grid -->
    </div> <!-- Cierre correcto de container -->
</section>