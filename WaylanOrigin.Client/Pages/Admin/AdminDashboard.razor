@page "/admin"
@inject ApiService ApiService
@inject NavigationManager NavigationManager

<div class="admin-dashboard-page">
    
    <!-- HEADER BAR -->
    <header class="admin-header">
        <div class="admin-header-container">
            <div class="brand-info">
                <img src="/logotipo/Logotipo Waylan Origin-Photoroom.png" alt="Waylan Logo" class="admin-logo" />
                <span class="admin-badge">PANEL ADMINISTRATIVO</span>
            </div>
            <div class="user-info-bar">
                <span>Hola, <strong>@ApiService.CurrentUser?.Nombre</strong></span>
                <button class="btn-logout" @onclick="HandleLogout">Cerrar Sesión</button>
            </div>
        </div>
    </header>

    @if (!ApiService.IsLoggedIn)
    {
        <!-- LOGIN PANEL FOR ADMINISTRATOR -->
        <div class="admin-login-box">
            <div class="login-card">
                <h2>Iniciar Sesión como Administrador</h2>
                <p>Ingresa tus credenciales autorizadas de Waylan Origin.</p>
                
                @if (!string.IsNullOrEmpty(loginErrorMessage))
                {
                    <div class="error-alert">@loginErrorMessage</div>
                }

                <div class="form-group">
                    <label>Correo Electrónico</label>
                    <input type="email" @bind="loginEmail" placeholder="admin@waylan.com" class="form-control-admin" />
                </div>
                <div class="form-group">
                    <label>Contraseña</label>
                    <input type="password" @bind="loginPassword" placeholder="••••••••" class="form-control-admin" />
                </div>
                <button class="btn-admin-submit" @onclick="HandleLogin" type="button">INGRESAR AL PANEL</button>
            </div>
        </div>
    }
    else if (!ApiService.IsAdmin)
    {
        <div class="unauthorized-box">
            <div class="unauthorized-card">
                <h2>Acceso Denegado</h2>
                <p>Tu cuenta no cuenta con permisos de administrador en el sistema.</p>
                <button class="btn-admin-submit" @onclick='() => NavigationManager.NavigateTo("/")'>IR AL INICIO</button>
            </div>
        </div>
    }
    else
    {
        <!-- MAIN DASHBOARD CONTENT -->
        <div class="dashboard-body">
            
            <!-- SIDE NAVIGATION TABS -->
            <aside class="dashboard-sidebar">
                <button class="sidebar-tab-btn @(activeTab == "productos" ? "active" : "")" @onclick='() => SetActiveTab("productos")'>
                    <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polygon points="12,2 2,22 22,22" />
                    </svg>
                    Gestión Productos
                </button>
                <button class="sidebar-tab-btn @(activeTab == "categorias" ? "active" : "")" @onclick='() => SetActiveTab("categorias")'>
                    <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="7" height="9" />
                        <rect x="14" y="3" width="7" height="5" />
                        <rect x="14" y="12" width="7" height="9" />
                        <rect x="3" y="16" width="7" height="5" />
                    </svg>
                    Gestión Categorías
                </button>
                <button class="sidebar-tab-btn @(activeTab == "pedidos" ? "active" : "")" @onclick='() => SetActiveTab("pedidos")'>
                    <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="9" cy="21" r="1" />
                        <circle cx="20" cy="21" r="1" />
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
                    </svg>
                    Pedidos de Clientes
                </button>
                <button class="sidebar-tab-btn @(activeTab == "usuarios" ? "active" : "")" @onclick='() => SetActiveTab("usuarios")'>
                    <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                    Control Usuarios
                </button>
            </aside>

            <!-- ACTION DISPLAY PANEL -->
            <main class="dashboard-content-panel">
                
                @if (activeTab == "productos")
                {
                    <!-- TAB 1: PRODUCT MANAGEMENT -->
                    <div class="panel-section">
                        <div class="panel-header-row">
                            <h2>Productos Registrados</h2>
                            <button class="btn-create-new" @onclick="OpenCreateProductModal">NUEVO PRODUCTO</button>
                        </div>

                        <div class="table-container">
                            <table class="admin-table">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Nombre</th>
                                        <th>Región</th>
                                        <th>Formato</th>
                                        <th>Precio</th>
                                        <th>Estado</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in products)
                                    {
                                        <tr>
                                            <td><strong>@p.Id</strong></td>
                                            <td>@p.Nombre</td>
                                            <td>@p.Region</td>
                                            <td>@p.Formato</td>
                                            <td>$@p.Precio.ToString("N0") COP</td>
                                            <td>
                                                <span class="status-badge @(p.Activo ? "active" : "inactive")">
                                                    @(p.Activo ? "Activo" : "Inactivo")
                                                </span>
                                            </td>
                                            <td>
                                                <button class="btn-action-edit" @onclick="() => OpenEditProductModal(p)">Editar</button>
                                                <button class="btn-action-status" @onclick="() => ToggleProductStatus(p)">
                                                    @(p.Activo ? "Desactivar" : "Activar")
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else if (activeTab == "categorias")
                {
                    <!-- TAB 2: CATEGORIES MANAGEMENT -->
                    <div class="panel-section">
                        <div class="panel-header-row">
                            <h2>Categorías de Productos</h2>
                            <div class="add-category-inline">
                                <input type="text" @bind="newCategoryName" placeholder="Nueva Categoría" class="form-control-inline" />
                                <button class="btn-create-new" @onclick="CreateCategory">AGREGAR</button>
                            </div>
                        </div>

                        <div class="table-container">
                            <table class="admin-table">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Nombre</th>
                                        <th>Estado</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var c in categories)
                                    {
                                        <tr>
                                            <td><strong>#@c.Id</strong></td>
                                            <td>
                                                @if (editingCategoryId == c.Id)
                                                {
                                                    <input type="text" @bind="editingCategoryName" class="form-control-table" />
                                                }
                                                else
                                                {
                                                    @c.Nombre
                                                }
                                            </td>
                                            <td>
                                                <span class="status-badge @(c.Activo ? "active" : "inactive")">
                                                    @(c.Activo ? "Activo" : "Inactivo")
                                                </span>
                                            </td>
                                            <td>
                                                @if (editingCategoryId == c.Id)
                                                {
                                                    <button class="btn-action-save" @onclick="() => SaveCategoryEdit(c)">Guardar</button>
                                                    <button class="btn-action-cancel" @onclick="CancelCategoryEdit">Cancelar</button>
                                                }
                                                else
                                                {
                                                    <button class="btn-action-edit" @onclick="() => StartCategoryEdit(c)">Editar</button>
                                                    <button class="btn-action-status" @onclick="() => ToggleCategoryStatus(c)">
                                                        @(c.Activo ? "Desactivar" : "Activar")
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else if (activeTab == "pedidos")
                {
                    <!-- TAB 3: ORDERS MANAGEMENT -->
                    <div class="panel-section">
                        <h2>Pedidos Recibidos</h2>

                        <div class="table-container">
                            <table class="admin-table">
                                <thead>
                                    <tr>
                                        <th>Código</th>
                                        <th>Fecha</th>
                                        <th>Cliente</th>
                                        <th>Total</th>
                                        <th>Estado</th>
                                        <th>Cambiar Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var o in orders)
                                    {
                                        <tr>
                                            <td><strong>@o.Codigo</strong></td>
                                            <td>@o.Fecha.ToLocalTime().ToString("g")</td>
                                            <td>@o.EmailCliente</td>
                                            <td>$@o.Total.ToString("N0") COP</td>
                                            <td>
                                                <span class="status-badge @(o.Estado == "Enviado" ? "active" : o.Estado == "Cancelado" ? "inactive" : "pending")">
                                                    @o.Estado
                                                </span>
                                            </td>
                                            <td>
                                                <select class="select-order-state" value="@o.Estado" @onchange='(e) => UpdateOrderState(o, e.Value?.ToString() ?? "")'>
                                                    <option value="Pendiente">Pendiente</option>
                                                    <option value="Enviado">Enviado</option>
                                                    <option value="Cancelado">Cancelado</option>
                                                </select>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else if (activeTab == "usuarios")
                {
                    <!-- TAB 4: USER CONTROL -->
                    <div class="panel-section">
                        <h2>Usuarios Registrados</h2>

                        <div class="table-container">
                            <table class="admin-table">
                                <thead>
                                    <tr>
                                        <th>Nombre</th>
                                        <th>Correo Electrónico</th>
                                        <th>Rol de Acceso</th>
                                        <th>Estado</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var u in users)
                                    {
                                        <tr>
                                            <td>@u.Nombre</td>
                                            <td>@u.Email</td>
                                            <td>
                                                <span class="role-badge @(u.Rol == "Admin" ? "admin" : "client")">
                                                    @u.Rol
                                                </span>
                                            </td>
                                            <td>
                                                <span class="status-badge @(u.Activo ? "active" : "inactive")">
                                                    @(u.Activo ? "Activo" : "Inactivo")
                                                </span>
                                            </td>
                                            <td>
                                                @if (u.Email != ApiService.CurrentUser?.Email)
                                                {
                                                    <button class="btn-action-status" @onclick="() => ToggleUserStatus(u)">
                                                        @(u.Activo ? "Desactivar" : "Activar")
                                                    </button>
                                                }
                                                else
                                                {
                                                    <span class="self-label">Cuenta Actual</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

            </main>
        </div>
    }

    <!-- POPUP MODAL FOR PRODUCT CREATE/EDIT -->
    @if (showProductModal)
    {
        <div class="modal-backdrop">
            <div class="modal-box">
                <div class="modal-header">
                    <h3>@(isEditingProduct ? "Editar Producto" : "Nuevo Producto")</h3>
                    <button class="btn-close-modal" @onclick="CloseProductModal">×</button>
                </div>
                <div class="modal-body">
                    
                    @if (!string.IsNullOrEmpty(formErrorMessage))
                    {
                        <div class="error-alert">@formErrorMessage</div>
                    }

                    <div class="form-row-2">
                        <div class="form-group">
                            <label>Nombre Comercial</label>
                            <input type="text" @bind="productFormNombre" placeholder="Waylan Classic" class="form-control-admin" />
                        </div>
                        <div class="form-group">
                            <label>Categoría</label>
                            <select @bind="productFormIdCategoria" class="form-control-admin">
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.Id">@cat.Nombre</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="form-row-2">
                        <div class="form-group">
                            <label>Tipo de Tueste</label>
                            <select @bind="productFormTueste" class="form-control-admin">
                                <option value="1">Claro</option>
                                <option value="2">Medio</option>
                                <option value="3">Oscuro</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Proceso de Café</label>
                            <select @bind="productFormProceso" class="form-control-admin">
                                <option value="1">Lavado</option>
                                <option value="2">Natural</option>
                                <option value="3">Honey</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row-2">
                        <div class="form-group">
                            <label>Precio Unitario (COP)</label>
                            <input type="number" @bind="productFormPrecio" class="form-control-admin" />
                        </div>
                        <div class="form-group">
                            <label>Stock Disponible</label>
                            <input type="number" min="0" @bind="productFormStock" class="form-control-admin" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Descripción del Producto</label>
                        <textarea @bind="productFormDescripcion" placeholder="Escribe una breve descripción del café..." rows="3" class="form-control-admin" style="resize: vertical;"></textarea>
                    </div>

                    <div class="form-group">
                        <label>Imagen del Empaque (Archivo Físico)</label>
                        <InputFile OnChange="HandleFileSelected" class="form-control-file" />
                        @if (isEditingProduct && !string.IsNullOrEmpty(editingProductImageUrl))
                        {
                            <span class="file-help">Actualmente tiene: <strong>@editingProductImageUrl</strong> (déjalo vacío si no deseas cambiarla).</span>
                        }
                    </div>

                    <!-- Notes selection Many-To-Many -->
                    <div class="form-group">
                        <label>Notas de Sabor Seleccionadas</label>
                        <div class="notes-selection-grid">
                            @foreach (var n in availableNotes)
                            {
                                <label class="checkbox-note-container">
                                    <input type="checkbox" checked="@productFormSelectedNoteIds.Contains(n.Id)" @onchange='() => ToggleFormNoteSelection(n.Id)' />
                                    <span class="note-label">@n.Nombre</span>
                                </label>
                            }
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button class="btn-cancel" @onclick="CloseProductModal">CANCELAR</button>
                    <button class="btn-save" @onclick="SaveProduct" type="button">GUARDAR PRODUCTO</button>
                </div>
            </div>
        </div>
    }

</div>

@code {
    private string activeTab = "productos";

    // Authentication States
    private string loginEmail = "";
    private string loginPassword = "";
    private string loginErrorMessage = "";

    // Entities lists
    private List<Product> products = new();
    private List<Category> categories = new();
    private List<Order> orders = new();
    private List<User> users = new();
    private List<Note> availableNotes = new();

    // Modals & Form variables
    private bool showProductModal = false;
    private bool isEditingProduct = false;
    private string formErrorMessage = "";

    private string productFormId = "";
    private string productFormNombre = "";
    private string productFormRegion = "Tolima, Colombia";
    private int productFormPrecio = 35000;
    private string productFormFormato = "Grano";
    private string productFormPerfilSabor = "Dulce";
    private string productFormMetodoRecomendado = "Filtrado";
    private int productFormIntensidad = 3;
    private string productFormEtiqueta = "";
    private string editingProductImageUrl = "";
    
    // New backend bindings
    private int productFormIdCategoria = 1;
    private int productFormTueste = 2; // Default Medio
    private int productFormProceso = 1; // Default Lavado
    private int productFormStock = 20;
    private string productFormDescripcion = "";

    private List<int> productFormSelectedNoteIds = new();
    private Microsoft.AspNetCore.Components.Forms.IBrowserFile? selectedImageFile;

    // Categories Inline edit
    private string newCategoryName = "";
    private int editingCategoryId = 0;
    private string editingCategoryName = "";

    protected override async Task OnInitializedAsync()
    {
        if (ApiService.IsLoggedIn)
        {
            await LoadActiveTabData();
        }
    }

    private async Task HandleLogin()
    {
        loginErrorMessage = "";
        if (string.IsNullOrEmpty(loginEmail) || string.IsNullOrEmpty(loginPassword))
        {
            loginErrorMessage = "Por favor ingresa todos los campos.";
            return;
        }

        var success = await ApiService.LoginAsync(loginEmail, loginPassword);
        if (success)
        {
            if (ApiService.IsAdmin)
            {
                await LoadActiveTabData();
            }
            else
            {
                ApiService.Logout();
                loginErrorMessage = "Acceso denegado. No eres administrador.";
            }
        }
        else
        {
            loginErrorMessage = "Credenciales incorrectas o usuario inactivo.";
        }
    }

    private void HandleLogout()
    {
        ApiService.Logout();
        NavigationManager.NavigateTo("/admin", forceLoad: true);
    }

    private async Task SetActiveTab(string tabName)
    {
        activeTab = tabName;
        await LoadActiveTabData();
    }

    private async Task LoadActiveTabData()
    {
        try
        {
            if (activeTab == "productos")
            {
                products = await ApiService.GetTodosProductosAsync();
                availableNotes = await ApiService.GetNotasAsync();
                categories = await ApiService.GetTodasCategoriasAsync(); // Needed for dropdown
            }
            else if (activeTab == "categorias")
            {
                categories = await ApiService.GetTodasCategoriasAsync();
            }
            else if (activeTab == "pedidos")
            {
                orders = await ApiService.GetTodosPedidosAsync();
            }
            else if (activeTab == "usuarios")
            {
                users = await ApiService.GetUsuariosAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando datos: {ex.Message}");
        }
    }

    // --- PRODUCTS OPERATIONS ---
    private void OpenCreateProductModal()
    {
        isEditingProduct = false;
        formErrorMessage = "";
        productFormId = "";
        productFormNombre = "";
        productFormRegion = "Tolima, Colombia";
        productFormPrecio = 35000;
        productFormFormato = "Grano";
        productFormPerfilSabor = "Dulce";
        productFormMetodoRecomendado = "Filtrado";
        productFormIntensidad = 3;
        productFormEtiqueta = "";
        
        productFormIdCategoria = categories.FirstOrDefault()?.Id ?? 1;
        productFormTueste = 2;
        productFormProceso = 1;
        productFormStock = 20;
        productFormDescripcion = "";
        
        productFormSelectedNoteIds.Clear();
        selectedImageFile = null;
        showProductModal = true;
    }

    private void OpenEditProductModal(Product p)
    {
        isEditingProduct = true;
        formErrorMessage = "";
        productFormId = p.Id;
        productFormNombre = p.Nombre;
        productFormRegion = p.Region;
        productFormPrecio = (int)p.Precio;
        productFormFormato = p.Formato;
        productFormPerfilSabor = p.PerfilSabor;
        productFormMetodoRecomendado = p.MetodoRecomendado;
        productFormIntensidad = p.Intensidad;
        productFormEtiqueta = p.Etiqueta;
        editingProductImageUrl = p.ImagenUrl;
        
        productFormIdCategoria = p.IdCategoria > 0 ? p.IdCategoria : (categories.FirstOrDefault(c => c.Nombre == p.Formato)?.Id ?? 1);
        productFormTueste = p.Tueste == "Claro" ? 1 : p.Tueste == "Oscuro" ? 3 : 2;
        productFormProceso = p.Proceso == "Natural" ? 2 : p.Proceso == "Honey" ? 3 : 1;
        productFormStock = p.Stock;
        productFormDescripcion = p.Descripcion ?? "";
        
        productFormSelectedNoteIds = p.Notas.Select(n => n.Id).ToList();
        selectedImageFile = null;
        showProductModal = true;
    }

    private void CloseProductModal()
    {
        showProductModal = false;
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedImageFile = e.File;
    }

    private void ToggleFormNoteSelection(int noteId)
    {
        if (productFormSelectedNoteIds.Contains(noteId))
            productFormSelectedNoteIds.Remove(noteId);
        else
            productFormSelectedNoteIds.Add(noteId);
    }

    private async Task SaveProduct()
    {
        formErrorMessage = "";
        if (string.IsNullOrEmpty(productFormNombre))
        {
            formErrorMessage = "Por favor, completa los campos requeridos (Nombre).";
            return;
        }

        if (!isEditingProduct && selectedImageFile == null)
        {
            formErrorMessage = "La imagen es obligatoria al crear un nuevo producto.";
            return;
        }

        var content = new MultipartFormDataContent();
        content.Add(new StringContent(productFormNombre), "Nombre");
        content.Add(new StringContent(productFormIdCategoria.ToString()), "IdCategoria");
        content.Add(new StringContent(productFormTueste.ToString()), "tueste");
        content.Add(new StringContent(productFormProceso.ToString()), "proceso");
        content.Add(new StringContent(productFormDescripcion), "Descripcion");
        content.Add(new StringContent(productFormPrecio.ToString()), "Precio");
        content.Add(new StringContent(productFormStock.ToString()), "Stock");

        // Legacy / Fallbacks
        content.Add(new StringContent(productFormRegion), "Region");
        content.Add(new StringContent(productFormFormato), "Formato");
        content.Add(new StringContent(productFormPerfilSabor), "PerfilSabor");
        content.Add(new StringContent(productFormMetodoRecomendado), "MetodoRecomendado");
        content.Add(new StringContent(productFormIntensidad.ToString()), "Intensidad");
        content.Add(new StringContent(productFormEtiqueta ?? ""), "Etiqueta");

        if (selectedImageFile != null)
        {
            var fileContent = new StreamContent(selectedImageFile.OpenReadStream(maxAllowedSize: 15 * 1024 * 1024)); // 15MB max
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(selectedImageFile.ContentType);
            content.Add(fileContent, "Imagen", selectedImageFile.Name);
        }

        if (productFormSelectedNoteIds.Any())
        {
            foreach (var nid in productFormSelectedNoteIds)
            {
                content.Add(new StringContent(nid.ToString()), "IdNotas");
            }
        }

        bool success;
        if (isEditingProduct)
        {
            success = await ApiService.ActualizarProductoAsync(productFormId, content);
        }
        else
        {
            success = await ApiService.CrearProductoAsync(content);
        }

        if (success)
        {
            showProductModal = false;
            await LoadActiveTabData();
        }
        else
        {
            formErrorMessage = "Ocurrió un error en el servidor. Verifica las reglas de notas e imágenes.";
        }
    }

    private async Task ToggleProductStatus(Product p)
    {
        var success = await ApiService.CambiarEstadoProductoAsync(p.Id, !p.Activo);
        if (success)
        {
            await LoadActiveTabData();
        }
    }

    // --- CATEGORIES OPERATIONS ---
    private async Task CreateCategory()
    {
        if (string.IsNullOrEmpty(newCategoryName)) return;
        var success = await ApiService.CrearCategoriaAsync(newCategoryName);
        if (success)
        {
            newCategoryName = "";
            await LoadActiveTabData();
        }
    }

    private void StartCategoryEdit(Category c)
    {
        editingCategoryId = c.Id;
        editingCategoryName = c.Nombre;
    }

    private void CancelCategoryEdit()
    {
        editingCategoryId = 0;
        editingCategoryName = "";
    }

    private async Task SaveCategoryEdit(Category c)
    {
        if (string.IsNullOrEmpty(editingCategoryName)) return;
        var success = await ApiService.ActualizarCategoriaAsync(c.Id, editingCategoryName);
        if (success)
        {
            editingCategoryId = 0;
            editingCategoryName = "";
            await LoadActiveTabData();
        }
    }

    private async Task ToggleCategoryStatus(Category c)
    {
        var success = await ApiService.CambiarEstadoCategoriaAsync(c.Id, !c.Activo);
        if (success)
        {
            await LoadActiveTabData();
        }
    }

    // --- ORDERS OPERATIONS ---
    private async Task UpdateOrderState(Order o, string newState)
    {
        var success = await ApiService.CambiarEstadoPedidoAsync(o.Codigo, newState);
        if (success)
        {
            await LoadActiveTabData();
        }
    }

    // --- USERS OPERATIONS ---
    private async Task ToggleUserStatus(User u)
    {
        var success = await ApiService.CambiarEstadoUsuarioAsync(u.Id, !u.Activo);
        if (success)
        {
            await LoadActiveTabData();
        }
    }
}

