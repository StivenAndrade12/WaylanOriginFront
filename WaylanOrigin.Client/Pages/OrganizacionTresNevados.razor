@page "/organizacion/tres-nevados"

<div class="tresnevados-container">

    <!-- Breadcrumb -->
    <div class="tn-breadcrumb">
        <a href="/productores"><span class="arrow">←</span> Productores Aliados</a>
        <span class="separator">&gt;</span>
        <span class="active">Tres Nevados</span>
    </div>

    <!-- Hero Section -->
    <div class="tn-hero">
        <div class="tn-hero-info">
            <h1 class="tn-main-title">TRES NEVADOS</h1>
            
            <div class="separador-contenedor">
                <img src="/logotipo/trn.png" alt="Logo Tres Nevados" class="icono-hoja">
                <div class="linea-dorada"></div>
            </div>

            <div class="contenido-texto">
                <p class="texto-descripcion">
                    Organización cafetera dedicada a preservar la tradición y el carácter de los cafés de montaña.
                </p>
                <p class="texto-descripcion">
                    Desde hace más de dos décadas trabajamos por el desarrollo del caficultor y la protección de nuestra región.
                </p>
            </div>
        </div>

        <div class="tn-hero-image">
            <img src="/imagenes/tresnevados-banner.png" alt="Caficultores Tres Nevados" />
        </div>
    </div>

    <!-- Panel de estadísticas -->
    <div class="tn-stats-panel">

        <div class="tn-stat-item">
            <div class="tn-stat-icon">
                <img src="/logotipo/org1.png" class="tn-icon-img" alt="Icono">
            </div>
            <h3 class="tn-stat-number">2001</h3>
            <p class="tn-stat-label">Año de fundación</p>
        </div>

        <div class="tn-stat-item">
            <div class="tn-stat-icon">
                <img src="/logotipo/org2.png" class="tn-icon-img" alt="Icono">
            </div>
            <h3 class="tn-stat-number">85+</h3>
            <p class="tn-stat-label">Familias caficultoras</p>
        </div>

        <div class="tn-stat-item">
            <div class="tn-stat-icon">
                <img src="/logotipo/org3.png" class="tn-icon-img" alt="Icono">
            </div>
            <h3 class="tn-stat-number">2.800+</h3>
            <p class="tn-stat-label">Hectáreas cultivadas</p>
        </div>

        <div class="tn-stat-item">
            <div class="tn-stat-icon">
                <img src="/logotipo/org4.png" class="tn-icon-img" alt="Icono">
            </div>
            <h3 class="tn-stat-number">Conservación</h3>
            <p class="tn-stat-label">Protección ambiental</p>
        </div>

    </div>

    <!-- Productores Grid Section -->
    <div class="tn-section-title-bar">
        <h2>Productores que hacen parte de Tres Nevados</h2>
        <a href="/todos-los-productores" class="tn-view-all">VER TODOS ➔</a>
    </div>

    <div class="tn-productores-grid">

        <div class="tn-producer-card">
            <div class="tn-card-img">
                <img src="/imagenes/ñ1.png" alt="Productor 1" />
            </div>
            <div class="tn-card-content">
                <h3>José Ramírez</h3>
                <p class="tn-finca">Finca Alto Nevado</p>
                <p class="tn-location">Tolima, Colombia</p>
                <a href="/perfil/jose" class="tn-btn-profile">VER PERFIL ➔</a>
            </div>
        </div>

        <div class="tn-producer-card">
            <div class="tn-card-img">
                <img src="/imagenes/ñ2.png" alt="Productor 2" />
            </div>
            <div class="tn-card-content">
                <h3>Lucía Herrera</h3>
                <p class="tn-finca">Finca La Cumbre</p>
                <p class="tn-location">Tolima, Colombia</p>
                <a href="/perfil/lucia" class="tn-btn-profile">VER PERFIL ➔</a>
            </div>
        </div>

        <div class="tn-producer-card">
            <div class="tn-card-img">
                <img src="/imagenes/ñ3.png" alt="Productor 3" />
            </div>
            <div class="tn-card-content">
                <h3>Óscar Benítez</h3>
                <p class="tn-finca">Finca El Mirador</p>
                <p class="tn-location">Tolima, Colombia</p>
                <a href="/perfil/oscar" class="tn-btn-profile">VER PERFIL ➔</a>
            </div>
        </div>

        <div class="tn-producer-card tn-more-card">
            <div class="tn-more-content">
                <div class="tn-user-icon">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#8B5E3C" stroke-width="1.5">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                </div>
                <p>Más productores</p>
                <a href="/todos-los-productores" class="tn-btn-profile tn-btn-all">VER TODOS ➔</a>
            </div>
        </div>

    </div>

</div>
